% !Mode:: "TeX:UTF-8:Main"
\documentclass{report}
\input{regression-test}

\newtheorem{theorem}{Theorem}
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{definition}[theorem]{Definition}
\def\thelemma{\Alph{lemma}}

\begin{document}
\START\showoutput
\makeatletter
\newcounteralias{mysection}{section}
\@addtoreset{lemma}{mysection}
\@removefromreset{lemma}{mysection}
\@addtoreset{theorem}{mysection}
\@addtoreset{theorem}{section}

\section{blub}

\begin{theorem}\label{theorem1}
    theorem counter: \@currentcounter
\end{theorem}
\begin{theorem}\label{theorem2}
    theorem counter: \@currentcounter
\end{theorem}
\stepcounter{mysection}
%\section{blub}
\begin{lemma}\label{lemma1}
   lemma counter: \@currentcounter
\end{lemma}

\begin{theorem}\label{theorem3}
    theorem counter: \@currentcounter
\end{theorem}

\begin{definition}\label{def}
   definition counter: \@currentcounter
\end{definition}
\end{document} 
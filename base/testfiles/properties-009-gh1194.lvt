\documentclass{article}
\input{regression-test}
\START

\SHOWFILE{\jobname.aux}
\renewcommand*{\thepage}{\textbf{\arabic{page}}}
\OMIT
\begin{document}
\TIMO

some text \RecordProperties{mylabel}{page}
\newcommand\testlabel{mylabel} \newcommand\proppage{page}
\ExplSyntaxOn
\TEST{unknown}
 {
   \ASSERT{0}
    {
      \property_item:nn { unknown } { page }
    }
 }
\TEST{item-1}
 {
   \ASSERT{\unexpanded{\textbf{1}}}
    {
      \property_item:nn { mylabel } { page }
    }
 }
\TEST{item-2}
 {
   \ASSERT{\unexpanded{\textbf{1}}}
    {
      \property_item:ee { \testlabel } { \proppage }
    }
 }
\TEST{unknown-local-default}
 {
   \ASSERT{my-default}
    {
      \property_item:nnn { unknown } { page } { my-default }
    }
 }
\TEST{item-1-local-default}
 {
   \ASSERT{\unexpanded{\textbf{1}}}
    {
      \property_item:nnn { mylabel } { page } { something-else }
    }
 }
\TEST{item-2-local-defaultv}
 {
   \ASSERT{\unexpanded{\textbf{1}}}
    {
      \property_item:een { \testlabel } { \proppage } { something-else }
    }
 }
\ExplSyntaxOff


\end{document}

     {bookmarksdepth      .meta:nn = {hyp/outline}{depth=#1},
      bookmarksopen       .meta:nn = {hyp/outline}{open},
      bookmarksopenlevel  .meta:nn = {hyp/outline}{openlevel=#1},
      bookmarksnumbered   .meta:nn = {hyp/outline}{numbered}}
   }

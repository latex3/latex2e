\DocumentMetadata{
 tagging=on
}
\input{regression-test}
\documentclass{article}
\usepackage{tikz}
\tikzset{
  my alt/.style 2 args={tagging-setup/alt=`#1' is for #2,},
  my actual/.style={actualtext=#1},
  my alt/.is tagging key,
  my actual/.is tagging key,
  my family/.is family,
  my key/.code={\def\mykey{My Key}},
  my key/.belongs to family=/tikz/my family,
}
\ExplSyntaxOn
\keys_define:nn {tag/graphic}{uko .code:n = {\typeout{uko:~#1}}}
\ExplSyntaxOff
\begin{document}
\START
\TEST{009 A}{%
  \begin{tikzpicture}[my alt={A}{ardvaark}]
    \LogSocket{tagsupport/tikz/picture/begin}
    \LogSocket{tagsupport/tikz/picture/end}
    \expandafter\csname tl_log:c\endcsname {l__tikz_tagging_alt_tl}
    \node {AAA};
  \end{tikzpicture}%
}
\TEST{009 B}{%
  \begin{tikzpicture}[tagging-setup/uko=bonobo]
    \node {BBB};
  \end{tikzpicture}%
}
\TEST{009 C}{%
  \begin{tikzpicture}[my actual=seas]
    \LogSocket{tagsupport/tikz/picture/begin}
    \LogSocket{tagsupport/tikz/picture/end}
    \expandafter\csname tl_log:c\endcsname {l__tikz_tagging_actualtext_tl}
    \node {CCC};
  \end{tikzpicture}%
}
\TEST{009 D}{%
  \pgfkeys{%
    /tikz/my family/.activate family,
    /pgf/key filters/active families/.install key filter,
  }%
  \begin{tikzpicture}[alt=Alt]
    \expandafter\typeout\expandafter{\csname mykey\endcsname}
    \pgfkeysfiltered{/tikz/my key}
    \expandafter\typeout\expandafter{\csname mykey\endcsname}
  \end{tikzpicture}%
}
\SHOWPDFTAGS
\end{document}


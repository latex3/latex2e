\DocumentMetadata{
 tagging=on
}
\input{regression-test}
\documentclass{article}
\usepackage{tikz}
\tikzset
 {
   my alt/.style 2 args={tagging-setup/alt=`#1' is for #2,},
   my alt/.belongs to family=/tikz/tagging-setup,
   my actual/.style={actualtext=#1},
   my actual/.belongs to family=/tikz/tagging-setup,
   my family/.is family,
   my key/.code={\def\mykey{My Key}},
   my key/.belongs to family=/tikz/my family,
   my secondkey/.code={\def\mysecondkey{My second Key}},
 }
\begin{document}
\START
\TEST{009 A: `my alt` key}{%
  \begin{tikzpicture}[my alt={A}{ardvaark}]
    \LogSocket{tagsupport/tikz/picture/begin}
    \LogSocket{tagsupport/tikz/picture/end}
    \UseName{tl_log:c}{l__tikz_tagging_alt_tl}
    \node {AAA};
  \end{tikzpicture}%
}

\TEST{010 B: `my actual` key}{%
  \begin{tikzpicture}[my actual=seas]
    \LogSocket{tagsupport/tikz/picture/begin}
    \LogSocket{tagsupport/tikz/picture/end}
    \UseName{tl_log:c}{l__tikz_tagging_actualtext_tl}   
    \node {BBB};
  \end{tikzpicture}%
}

\TEST{010 C: test filter localization}{%
  \pgfkeys{%
    /tikz/my family/.activate family,
    /pgf/key filters/active families/.install key filter,
  }%
  \begin{tikzpicture}[alt=Alt]
    \typeout{\UseName{mykey}, \UseName{mysecondkey}}
    \pgfkeysfiltered{/tikz/my key,/tikz/my secondkey}
    \typeout{\UseName{mykey}, \UseName{mysecondkey}}
    \node{CCC};
  \end{tikzpicture}%
}
\SHOWPDFTAGS
\end{document}
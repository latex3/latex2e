      <text xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.063"
         xmlns:Layout="http://iso.org/pdf/ssn/Layout"
         Layout:TextAlign="Justify"
         rolemaps-to="P"
        >
       <?MarkedContent page="2" ?>Core
       <Span xmlns="http://iso.org/pdf2/ssn"
          id="ID.064"
          actualtext="LaTeX"
          phoneme="[ˈlaːtɛx]"
         >
        <?MarkedContent page="2" ?>LATEX
       </Span>
       <?MarkedContent page="2" ?>doesn’t offer much here, for serious math seeamsmath which is alsosupported.
      </text>
     </text-unit>
     <text-unit xmlns="https://www.latex-project.org/ns/dflt"
        id="ID.065"
        rolemaps-to="Part"
       >
      <text xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.066"
         xmlns:Layout="http://iso.org/pdf/ssn/Layout"
         Layout:TextAlign="Justify"
         rolemaps-to="P"
        >
       <?MarkedContent page="2" ?>The middle column can be anything, not just
       <Formula xmlns="http://iso.org/pdf2/ssn"
          id="ID.067"
          title="math"
          af="tag-AFfile1.tex"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:Placement="Inline"
         >
         <AssociatedFile name="tag-AFfile1.tex" xmlns="">
         $=$
         </AssociatedFile>
        <?MarkedContent page="2" ?>=
       </Formula>
       <?MarkedContent page="2" ?>.
      </text>
      <Formula xmlns="http://iso.org/pdf2/ssn"
         id="ID.068"
         title="eqnarray"
         af="tag-AFfile2.tex"
         xmlns:Layout="http://iso.org/pdf/ssn/Layout"
         Layout:Placement="Block"
        >
        <AssociatedFile name="tag-AFfile2.tex" xmlns="">
        \begin {eqnarray}x &amp; = &amp; 17y \\ y &amp; &lt; &amp; a+b+c+d+e+f+g+h+i+j+ \nonumber \\ &amp; &amp; k+l+m+n+o+p\end {eqnarray}
        </AssociatedFile>
       <?MarkedContent page="2" ?>x = 17y
       <Lbl xmlns="http://iso.org/pdf2/ssn"
          id="ID.069"
         >
        <?MarkedContent page="2" ?>(3.1)
       </Lbl>
       <?MarkedContent page="2" ?>y&lt;a +b +c +d +e +f +g +h +i +j +k +l +m +n +o +p
       <Lbl xmlns="http://iso.org/pdf2/ssn"
          id="ID.070"
         >
        <?MarkedContent page="2" ?>(3.2)
       </Lbl>
       <?MarkedContent page="2" ?>
      </Formula>
     </text-unit>
     <text-unit xmlns="https://www.latex-project.org/ns/dflt"
        id="ID.071"
        rolemaps-to="Part"
       >
      <text xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.072"
         xmlns:Layout="http://iso.org/pdf/ssn/Layout"
         Layout:TextAlign="Justify"
         rolemaps-to="P"
        >
       <?MarkedContent page="2" ?>And there iseqnarray*:
      </text>
      <Formula xmlns="http://iso.org/pdf2/ssn"
         id="ID.073"
         title="eqnarray*"
         af="tag-AFfile3.tex"
         xmlns:Layout="http://iso.org/pdf/ssn/Layout"
         Layout:Placement="Block"
        >
        <AssociatedFile name="tag-AFfile3.tex" xmlns="">
        \begin {eqnarray*}x &amp; \ll &amp; y_1 + \cdots + y_n \\ &amp; \leq &amp; z\end {eqnarray*}
        </AssociatedFile>
       <?MarkedContent page="2" ?>x≪y1+··· +yn≤z
      </Formula>

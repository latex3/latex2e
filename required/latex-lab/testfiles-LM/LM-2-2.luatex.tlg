         rolemaps-to="P"
        >
       <?MarkedContent page="2" ?>As any dedicated reader can clearly see, the Ideal of practical reason is a rep-resentation of, as far as I know, the things in themselves; as I have shown elsewhere, the phenomena should only be used as a canon for our understand-ing.
      </text>
     </text-unit>
     <Sect xmlns="http://iso.org/pdf2/ssn"
        id="ID.0077"
       >
      <subsubsection xmlns="https://www.latex-project.org/ns/book"
         id="ID.0078"
         title="Quotation Marks"
         rolemaps-to="H4"
        >
       <?MarkedContent page="2" ?>Quotation Marks
      </subsubsection>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0079"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0080"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="2" ?>Quote test: “The paralogisms of practical reason are what first give rise to the architectonic of practical reason. ” and some more text. and ‘As will easily be shown in the next section, reason would thereby be made to contradict, in view of these considerations, the Ideal of practical reason, yet the manifold depends on the phenomena. ’ even more.
       </text>
      </text-unit>
     </Sect>
     <Sect xmlns="http://iso.org/pdf2/ssn"
        id="ID.0081"
       >
      <subsubsection xmlns="https://www.latex-project.org/ns/book"
         id="ID.0082"
         title="Simple Text-Generating Commands"
         rolemaps-to="H4"
        >
       <?MarkedContent page="2" ?>Simple Text-Generating Commands
      </subsubsection>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0083"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0084"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="2" ?>Some people use plain 
        <Span xmlns="http://iso.org/pdf2/ssn"
           id="ID.0085"
           actualtext="TeX"
          >
         <?MarkedContent page="2" ?>TEX
        </Span>
        <?MarkedContent page="2" ?>, but I prefer 
        <Span xmlns="http://iso.org/pdf2/ssn"
           id="ID.0086"
           actualtext="LaTeX"
           phoneme="[ˈlaːtɛx]"
          >
         <?MarkedContent page="2" ?>LATEX
        </Span>
        <?MarkedContent page="2" ?> instead.
       </text>
      </text-unit>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0087"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0088"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="2" ?>This page was produced May 20, 2016.
       </text>
      </text-unit>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0089"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0090"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="2" ?>If nominated ..., I will not serve.
       </text>
      </text-unit>
     </Sect>
     <Sect xmlns="http://iso.org/pdf2/ssn"
        id="ID.0091"
       >
      <subsubsection xmlns="https://www.latex-project.org/ns/book"
         id="ID.0092"
         title="Emphasizing Text"
         rolemaps-to="H4"
        >
       <?MarkedContent page="3" ?>Emphasizing Text
      </subsubsection>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0093"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0094"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <Span xmlns="http://iso.org/pdf2/ssn"
           id="ID.0095"
           actualtext="LaTeX"
           phoneme="[ˈlaːtɛx]"
          >
         <?MarkedContent page="3" ?>LATEX
        </Span>
        <?MarkedContent page="3" ?> offers 
        <Em xmlns="http://iso.org/pdf2/ssn"
           id="ID.0096"
          >
         <?MarkedContent page="3" ?>one command
        </Em>
        <?MarkedContent page="3" ?> and one declaration for emphasis.
       </text>
      </text-unit>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0097"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0098"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <Code xmlns="http://iso.org/pdf/ssn"
           id="ID.0099"
          >
         <?MarkedContent page="3" ?>\emph
        </Code>
        <?MarkedContent page="3" ?> is done in latex-lab-text, but how to handle 
        <Code xmlns="http://iso.org/pdf/ssn"
           id="ID.0100"
          >
         <?MarkedContent page="3" ?>\em
        </Code>
        <?MarkedContent page="3" ?> is unclear as it can go over paragraphs.
       </text>
      </text-unit>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0101"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0102"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="3" ?>strong aka bold face is mapped to /Strong, but here too it is unclear how to handle the switch.
       </text>
      </text-unit>
     </Sect>
     <Sect xmlns="http://iso.org/pdf2/ssn"
        id="ID.0103"
       >
      <subsubsection xmlns="https://www.latex-project.org/ns/book"
         id="ID.0104"
         title="Preventing Line Breaks"
         rolemaps-to="H4"
        >
       <?MarkedContent page="3" ?>Preventing Line Breaks
      </subsubsection>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0105"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0106"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="3" ?>Anything to do here? If so, what for Mr. Jones and Figure 7
       </text>
      </text-unit>
     </Sect>
     <Sect xmlns="http://iso.org/pdf2/ssn"
        id="ID.0107"
       >
      <subsubsection xmlns="https://www.latex-project.org/ns/book"
         id="ID.0108"
         title="Footnotes"
         rolemaps-to="H4"
        >
       <?MarkedContent page="3" ?>Footnotes
      </subsubsection>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0109"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0110"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="3" ?>Footnotes
        <footnotemark xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0111"
           rolemaps-to="Lbl"
           referenced-as="2"
          >
          <?References objects="1" ?>
         <Span xmlns="http://iso.org/pdf2/ssn"
            id="ID.0112"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextPosition="Sup"
           >
          <?MarkedContent page="3" ?>1
         </Span>
        </footnotemark>
        <footnote xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0113"
           rolemaps-to="FENote"
           referenced-as="1"
          >
          <?References objects="2" ?>
         <footnotelabel xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0116"
            rolemaps-to="Lbl"
           >
          <Span xmlns="http://iso.org/pdf2/ssn"
             id="ID.0117"
             xmlns:Layout="http://iso.org/pdf/ssn/Layout"
             Layout:TextPosition="Sup"
            >
           <?MarkedContent page="3" ?>1
          </Span>
         </footnotelabel>
         <text-unit xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0114"
            rolemaps-to="Part"
           >
          <text xmlns="https://www.latex-project.org/ns/dflt"
             id="ID.0115"
             xmlns:Layout="http://iso.org/pdf/ssn/Layout"
             Layout:TextAlign="Justify"
             rolemaps-to="P"
            >
           <?MarkedContent page="3" ?>Like this one
          </text>
         </text-unit>
        </footnote>
        <?MarkedContent page="3" ?> should be fine, as well as simple footnote marks
        <footnotemark xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0118"
           rolemaps-to="Lbl"
           referenced-as="4"
          >
          <?References objects="3" ?>
         <Span xmlns="http://iso.org/pdf2/ssn"
            id="ID.0119"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextPosition="Sup"
           >
          <?MarkedContent page="3" ?>2
         </Span>
        </footnotemark>
        <?MarkedContent page="3" ?> with the text being supplied later.
       </text>
      </text-unit>
      <footnote xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0120"
         rolemaps-to="FENote"
         referenced-as="3"
        >
        <?References objects="4" ?>
       <footnotelabel xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0123"
          rolemaps-to="Lbl"
         >
        <Span xmlns="http://iso.org/pdf2/ssn"
           id="ID.0124"
           xmlns:Layout="http://iso.org/pdf/ssn/Layout"
           Layout:TextPosition="Sup"
          >
         <?MarkedContent page="3" ?>2
        </Span>
       </footnotelabel>
       <text-unit xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0121"
          rolemaps-to="Part"
         >
        <text xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0122"
           xmlns:Layout="http://iso.org/pdf/ssn/Layout"
           Layout:TextAlign="Justify"
           rolemaps-to="P"
          >
         <?MarkedContent page="3" ?>The one for the mark. For good measure have a second paragraph.
        </text>
       </text-unit>
       <text-unit xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0125"
          rolemaps-to="Part"
         >
        <text xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0126"
           xmlns:Layout="http://iso.org/pdf/ssn/Layout"
           Layout:TextAlign="Justify"
           rolemaps-to="P"
          >
         <?MarkedContent page="3" ?>Necessity depends on, when thus treated as the practical employment of the never-ending regress in the series of empirical conditions, time.
        </text>
       </text-unit>
      </footnote>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0127"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0128"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="3" ?>Question is: is this placed correctly?
       </text>
      </text-unit>
     </Sect>
     <Sect xmlns="http://iso.org/pdf2/ssn"
        id="ID.0129"
       >
      <subsubsection xmlns="https://www.latex-project.org/ns/book"
         id="ID.0130"
         title="Formulas"
         rolemaps-to="H4"
        >
       <?MarkedContent page="3" ?>Formulas
      </subsubsection>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0131"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0132"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="3" ?>They should be fine too (and tested elsewhere). But here are the cases covered in this section of the manual: 
        <Formula xmlns="http://iso.org/pdf2/ssn"
           id="ID.0133"
           title="math"
           af="tag-AFfile1.tex"
           xmlns:Layout="http://iso.org/pdf/ssn/Layout"
           Layout:Placement="Inline"
          >
          <AssociatedFile name="tag-AFfile1.tex" xmlns="">
          $a+b$
          </AssociatedFile>
         <?MarkedContent page="3" ?>a+b
        </Formula>
        <?MarkedContent page="3" ?> is a short formula, 
        <Formula xmlns="http://iso.org/pdf2/ssn"
           id="ID.0134"
           title="math"
           af="tag-AFfile2.tex"
           xmlns:Layout="http://iso.org/pdf/ssn/Layout"
           Layout:Placement="Inline"
          >
          <AssociatedFile name="tag-AFfile2.tex" xmlns="">
          $x$
          </AssociatedFile>
         <?MarkedContent page="3" ?>x
        </Formula>
        <?MarkedContent page="3" ?> is a variable and one can use a math environment: 
        <Formula xmlns="http://iso.org/pdf2/ssn"
           id="ID.0135"
           title="math"
           af="tag-AFfile3.tex"
           xmlns:Layout="http://iso.org/pdf/ssn/Layout"
           Layout:Placement="Inline"
          >
          <AssociatedFile name="tag-AFfile3.tex" xmlns="">
          $a-b$
          </AssociatedFile>
         <?MarkedContent page="3" ?>a−b
        </Formula>
        <?MarkedContent page="3" ?> though this is seldom done.
       </text>
      </text-unit>
     </Sect>
    </Sect>
    <Sect xmlns="http://iso.org/pdf2/ssn"
       id="ID.0136"
      >
     <subsection xmlns="https://www.latex-project.org/ns/book"
        id="ID.0137"
        title="The Document"
        rolemaps-to="H3"
       >
      <section-number xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0138"
         rolemaps-to="Span"
        >
       <?MarkedContent page="3" ?>2.2.2 
      </section-number>
      <?MarkedContent page="3" ?>The Document
     </subsection>
     <Sect xmlns="http://iso.org/pdf2/ssn"
        id="ID.0139"
       >
      <subsubsection xmlns="https://www.latex-project.org/ns/book"
         id="ID.0140"
         title="The Title ``Page''"
         rolemaps-to="H4"
        >
       <?MarkedContent page="3" ?>The Title “Page”
      </subsubsection>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0141"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0142"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="3" ?>The title is tested at the beginning of the document. What of it needs further structure?
       </text>
      </text-unit>
     </Sect>
    </Sect>
    <Sect xmlns="http://iso.org/pdf2/ssn"
       id="ID.0143"
      >
     <subsection xmlns="https://www.latex-project.org/ns/book"
        id="ID.0144"
        title="Sectioning"
        rolemaps-to="H3"
       >
      <section-number xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0145"
         rolemaps-to="Span"
        >
       <?MarkedContent page="3" ?>2.2.3 
      </section-number>
      <?MarkedContent page="3" ?>Sectioning
     </subsection>
     <text-unit xmlns="https://www.latex-project.org/ns/dflt"
        id="ID.0146"
        rolemaps-to="Part"
       >
      <text xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0147"
         xmlns:Layout="http://iso.org/pdf/ssn/Layout"
         Layout:TextAlign="Justify"
         rolemaps-to="P"
        >
       <?MarkedContent page="3" ?>In this document we can in theory test all sectioning commands other than 
       <Code xmlns="http://iso.org/pdf/ssn"
          id="ID.0148"
         >
        <?MarkedContent page="3" ?>\chapter
       </Code>
       <?MarkedContent page="3" ?>, but this is best done elsewhere, to keep the heading setup of this test in sync with the 
       <Span xmlns="http://iso.org/pdf2/ssn"
          id="ID.0149"
          actualtext="LaTeX"
          phoneme="[ˈlaːtɛx]"
         >
        <?MarkedContent page="3" ?>LATEX
       </Span>
       <?MarkedContent page="3" ?> Manual.
      </text>
     </text-unit>
    </Sect>
    <Sect xmlns="http://iso.org/pdf2/ssn"
       id="ID.0150"
      >
     <subsection xmlns="https://www.latex-project.org/ns/book"
        id="ID.0151"
        title="Displayed Material"
        rolemaps-to="H3"
       >
      <section-number xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0152"
         rolemaps-to="Span"
        >
       <?MarkedContent page="3" ?>2.2.4 
      </section-number>
      <?MarkedContent page="3" ?>Displayed Material
     </subsection>
     <text-unit xmlns="https://www.latex-project.org/ns/dflt"
        id="ID.0153"
        rolemaps-to="Part"
       >
      <text xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0154"
         xmlns:Layout="http://iso.org/pdf/ssn/Layout"
         Layout:TextAlign="Justify"
         rolemaps-to="P"
        >
       <?MarkedContent page="3" ?>An example of a display quotation.
      </text>
      <quote xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0155"
         rolemaps-to="BlockQuote"
        >
       <text-unit xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0156"
          rolemaps-to="Part"
         >
        <text xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0157"
           xmlns:Layout="http://iso.org/pdf/ssn/Layout"
           Layout:TextAlign="Justify"
           rolemaps-to="P"
          >
         <?MarkedContent page="3" ?>... it’s a good idea to make your input file as easy to read as possible.
        </text>
       </text-unit>
      </quote>
      <text xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0158"
         xmlns:Layout="http://iso.org/pdf/ssn/Layout"
         Layout:TextAlign="Justify"
         rolemaps-to="P"
        >
       <?MarkedContent page="3" ?>I should be indented on both sides.
      </text>
     </text-unit>
     <Sect xmlns="http://iso.org/pdf2/ssn"
        id="ID.0159"
       >
      <subsubsection xmlns="https://www.latex-project.org/ns/book"
         id="ID.0160"
         title="Quotation"
         rolemaps-to="H4"
        >
       <?MarkedContent page="4" ?>Quotation
      </subsubsection>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0161"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0162"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="4" ?>Quotations with several paragraphs. As any dedicated reader can clearly see, the Ideal of practical reason is a representation of, as far as I know, the things in themselves; as I have shown elsewhere, the phenomena should only be used as a canon for our understanding.
       </text>
       <quote xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0163"
          rolemaps-to="BlockQuote"
         >
        <text-unit xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0164"
           rolemaps-to="Part"
          >
         <text xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0165"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextAlign="Justify"
            rolemaps-to="P"
           >
          <?MarkedContent page="4" ?>Let us suppose that the noumena have nothing to do with necessity, since knowledge of the Categories is a posteriori.
         </text>
        </text-unit>
        <text-unit xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0166"
           rolemaps-to="Part"
          >
         <text xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0167"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextAlign="Justify"
            rolemaps-to="P"
           >
          <?MarkedContent page="4" ?>Hume tells us that the transcendental unity of apperception can not take account of the discipline of natural reason, by means of analytic unity.
         </text>
        </text-unit>
        <text-unit xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0168"
           rolemaps-to="Part"
          >
         <text xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0169"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextAlign="Justify"
            rolemaps-to="P"
           >
          <?MarkedContent page="4" ?>It remains a mystery why the Ideal stands in need of reason.
         </text>
        </text-unit>
       </quote>
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0170"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="4" ?>And now the same with the quotation environment:
       </text>
       <quotation xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0171"
          rolemaps-to="BlockQuote"
         >
        <text-unit xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0172"
           rolemaps-to="Part"
          >
         <text xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0173"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextAlign="Justify"
            rolemaps-to="P"
           >
          <?MarkedContent page="4" ?>Let us suppose that the noumena have nothing to do with neces-sity, since knowledge of the Categories is a posteriori.
         </text>
        </text-unit>
        <text-unit xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0174"
           rolemaps-to="Part"
          >
         <text xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0175"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextAlign="Justify"
            rolemaps-to="P"
           >
          <?MarkedContent page="4" ?>Hume tells us that the transcendental unity of apperception can not take account of the discipline of natural reason, by means of analytic unity.
         </text>
        </text-unit>
        <text-unit xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0176"
           rolemaps-to="Part"
          >
         <text xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0177"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextAlign="Justify"
            rolemaps-to="P"
           >
          <?MarkedContent page="4" ?>It remains a mystery why the Ideal stands in need of reason.
         </text>
        </text-unit>
       </quotation>
      </text-unit>
     </Sect>
     <Sect xmlns="http://iso.org/pdf2/ssn"
        id="ID.0178"
       >
      <subsubsection xmlns="https://www.latex-project.org/ns/book"
         id="ID.0179"
         title="Lists"
         rolemaps-to="H4"
        >
       <?MarkedContent page="4" ?>Lists
      </subsubsection>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0180"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0181"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="4" ?>Lists come in three basic flavors, itemize, enumerate, and description. Here is an example of nested lists.
       </text>
       <itemize xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0182"
          xmlns:List="http://iso.org/pdf/ssn/List"
          List:ListNumbering="Unordered"
          rolemaps-to="L"
         >
        <item xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0183"
           rolemaps-to="LI"
          >
         <itemlabel xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0184"
            rolemaps-to="Lbl"
           >
          <?MarkedContent page="4" ?>•
         </itemlabel>
         <itembody xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0185"
            rolemaps-to="LBody"
           >
          <text-unit xmlns="https://www.latex-project.org/ns/dflt"
             id="ID.0186"
             rolemaps-to="Part"
            >
           <text xmlns="https://www.latex-project.org/ns/dflt"
              id="ID.0187"
              xmlns:Layout="http://iso.org/pdf/ssn/Layout"
              Layout:TextAlign="Justify"
              rolemaps-to="P"
             >
            <?MarkedContent page="4" ?>As any dedicated reader can clearly see, the Ideal of practical reason is a representation of, as far as I know, the things in themselves; as I have shown elsewhere, the phenomena should only be used as a canon for our understanding.
           </text>
          </text-unit>
         </itembody>
        </item>
        <item xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0188"
           rolemaps-to="LI"
          >
         <itemlabel xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0189"
            rolemaps-to="Lbl"
           >
          <?MarkedContent page="4" ?>•
         </itemlabel>
         <itembody xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0190"
            rolemaps-to="LBody"
           >
          <text-unit xmlns="https://www.latex-project.org/ns/dflt"
             id="ID.0191"
             rolemaps-to="Part"
            >
           <text xmlns="https://www.latex-project.org/ns/dflt"
              id="ID.0192"
              xmlns:Layout="http://iso.org/pdf/ssn/Layout"
              Layout:TextAlign="Justify"
              rolemaps-to="P"
             >
            <?MarkedContent page="4" ?>They can be nested:
           </text>
           <enumerate xmlns="https://www.latex-project.org/ns/dflt"
              id="ID.0193"
              xmlns:List="http://iso.org/pdf/ssn/List"
              List:ListNumbering="Ordered"
              rolemaps-to="L"
             >
            <item xmlns="https://www.latex-project.org/ns/dflt"
               id="ID.0194"
               rolemaps-to="LI"
              >
             <itemlabel xmlns="https://www.latex-project.org/ns/dflt"
                id="ID.0195"
                rolemaps-to="Lbl"
               >
              <?MarkedContent page="4" ?>1.
             </itemlabel>
             <itembody xmlns="https://www.latex-project.org/ns/dflt"
                id="ID.0196"
                rolemaps-to="LBody"
               >
              <text-unit xmlns="https://www.latex-project.org/ns/dflt"
                 id="ID.0197"
                 rolemaps-to="Part"
                >
               <text xmlns="https://www.latex-project.org/ns/dflt"
                  id="ID.0198"
                  xmlns:Layout="http://iso.org/pdf/ssn/Layout"
                  Layout:TextAlign="Justify"
                  rolemaps-to="P"
                 >
                <?MarkedContent page="4" ?>The paralogisms of practical reason are what first give rise to the architectonic of practical reason.
               </text>
              </text-unit>
             </itembody>
            </item>
            <item xmlns="https://www.latex-project.org/ns/dflt"
               id="ID.0199"
               rolemaps-to="LI"
              >
             <itemlabel xmlns="https://www.latex-project.org/ns/dflt"
                id="ID.0200"
                rolemaps-to="Lbl"
               >
              <?MarkedContent page="4" ?>2.
             </itemlabel>
             <itembody xmlns="https://www.latex-project.org/ns/dflt"
                id="ID.0201"
                rolemaps-to="LBody"
               >
              <text-unit xmlns="https://www.latex-project.org/ns/dflt"
                 id="ID.0202"
                 rolemaps-to="Part"
                >
               <text xmlns="https://www.latex-project.org/ns/dflt"
                  id="ID.0203"
                  xmlns:Layout="http://iso.org/pdf/ssn/Layout"
                  Layout:TextAlign="Justify"
                  rolemaps-to="P"
                 >
                <?MarkedContent page="4" ?>As will easily be shown in the next section, reason would thereby be made to contradict, in view of these considerations, the Ideal of practical reason, yet the manifold depends on the phenomena.
               </text>
              </text-unit>
             </itembody>
            </item>
           </enumerate>
          </text-unit>
         </itembody>
        </item>
        <item xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0204"
           rolemaps-to="LI"
          >
         <itemlabel xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0205"
            rolemaps-to="Lbl"
           >
          <?MarkedContent page="4" ?>•
         </itemlabel>
         <itembody xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0206"
            rolemaps-to="LBody"
           >
          <text-unit xmlns="https://www.latex-project.org/ns/dflt"
             id="ID.0207"
             rolemaps-to="Part"
            >
           <text xmlns="https://www.latex-project.org/ns/dflt"
              id="ID.0208"
              xmlns:Layout="http://iso.org/pdf/ssn/Layout"
              Layout:TextAlign="Justify"
              rolemaps-to="P"
             >
            <?MarkedContent page="4" ?>Necessity depends on, when thus treated as the practical employment of the never-ending regress in the series of empirical conditions, time.
           </text>
          </text-unit>
         </itembody>
        </item>
       </itemize>
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0209"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="4" ?>Some text directly following the list.
       </text>
      </text-unit>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0210"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0211"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="4" ?>Here is an example of a description list:
       </text>
       <description xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0212"
          xmlns:List="http://iso.org/pdf/ssn/List"
          List:ListNumbering="Description"
          rolemaps-to="L"
         >
        <item xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0213"
           rolemaps-to="LI"
          >
         <itemlabel xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0214"
            rolemaps-to="Lbl"
           >
          <?MarkedContent page="5" ?>Term A
         </itemlabel>
         <itembody xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0215"
            rolemaps-to="LBody"
           >
          <text-unit xmlns="https://www.latex-project.org/ns/dflt"
             id="ID.0216"
             rolemaps-to="Part"
            >
           <text xmlns="https://www.latex-project.org/ns/dflt"
              id="ID.0217"
              xmlns:Layout="http://iso.org/pdf/ssn/Layout"
              Layout:TextAlign="Justify"
              rolemaps-to="P"
             >
            <?MarkedContent page="5" ?>As any dedicated reader can clearly see, the Ideal of practical reason is a representation of, as far as I know, the things in themselves; as I have shown elsewhere, the phenomena should only be used as a canon for our understanding.
           </text>
          </text-unit>
         </itembody>
        </item>
        <item xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0218"
           rolemaps-to="LI"
          >
         <itemlabel xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0219"
            rolemaps-to="Lbl"
           >
          <?MarkedContent page="5" ?>Term B
         </itemlabel>
         <itembody xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0220"
            rolemaps-to="LBody"
           >
          <text-unit xmlns="https://www.latex-project.org/ns/dflt"
             id="ID.0221"
             rolemaps-to="Part"
            >
           <text xmlns="https://www.latex-project.org/ns/dflt"
              id="ID.0222"
              xmlns:Layout="http://iso.org/pdf/ssn/Layout"
              Layout:TextAlign="Justify"
              rolemaps-to="P"
             >
            <?MarkedContent page="5" ?>The paralogisms of practical reason are what first give rise to the architectonic of practical reason.
           </text>
          </text-unit>
         </itembody>
        </item>
       </description>
      </text-unit>
     </Sect>
     <Sect xmlns="http://iso.org/pdf2/ssn"
        id="ID.0223"
       >
      <subsubsection xmlns="https://www.latex-project.org/ns/book"
         id="ID.0224"
         title="Poetry"
         rolemaps-to="H4"
        >
       <?MarkedContent page="5" ?>Poetry
      </subsubsection>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0225"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0226"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="5" ?>An example of verse.
       </text>
      </text-unit>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0227"
         rolemaps-to="Part"
        >
       <quote xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0228"
          rolemaps-to="BlockQuote"
         >
        <text-unit xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0229"
           rolemaps-to="Part"
          >
         <text xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0230"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextAlign="Justify"
            rolemaps-to="P"
           >
          <?MarkedContent page="5" ?>There is an environment for verse
         </text>
        </text-unit>
        <text-unit xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0231"
           rolemaps-to="Part"
          >
         <text xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0232"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextAlign="Justify"
            rolemaps-to="P"
           >
          <?MarkedContent page="5" ?>Whole features some poets will curse.
         </text>
        </text-unit>
        <text-unit xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0233"
           rolemaps-to="Part"
          >
         <text xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0234"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextAlign="Justify"
            rolemaps-to="P"
           >
          <?MarkedContent page="5" ?>For instead of making
         </text>
        </text-unit>
        <text-unit xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0235"
           rolemaps-to="Part"
          >
         <text xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0236"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextAlign="Justify"
            rolemaps-to="P"
           >
          <?MarkedContent page="5" ?>Them do 
          <Em xmlns="http://iso.org/pdf2/ssn"
             id="ID.0237"
            >
           <?MarkedContent page="5" ?>all
          </Em>
          <?MarkedContent page="5" ?> the line breaking,
         </text>
        </text-unit>
        <text-unit xmlns="https://www.latex-project.org/ns/dflt"
           id="ID.0238"
           rolemaps-to="Part"
          >
         <text xmlns="https://www.latex-project.org/ns/dflt"
            id="ID.0239"
            xmlns:Layout="http://iso.org/pdf/ssn/Layout"
            Layout:TextAlign="Justify"
            rolemaps-to="P"
           >
          <?MarkedContent page="5" ?>It allows them to put too many words on a line when they’d rather be forced to be terse.
         </text>
        </text-unit>
       </quote>
      </text-unit>
     </Sect>
     <Sect xmlns="http://iso.org/pdf2/ssn"
        id="ID.0240"
       >
      <subsubsection xmlns="https://www.latex-project.org/ns/book"
         id="ID.0241"
         title="Displayed equation"
         rolemaps-to="H4"
        >
       <?MarkedContent page="5" ?>Displayed equation
      </subsubsection>
      <text-unit xmlns="https://www.latex-project.org/ns/dflt"
         id="ID.0242"
         rolemaps-to="Part"
        >
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0243"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="5" ?>Basic environments are 
        <Code xmlns="http://iso.org/pdf/ssn"
           id="ID.0244"
          >
         <?MarkedContent page="5" ?>\[...\]
        </Code>
        <?MarkedContent page="5" ?> and equation, e.g.,
       </text>
       <Formula xmlns="http://iso.org/pdf2/ssn"
          id="ID.0245"
          title="equation*"
          af="tag-AFfile4.tex"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:Placement="Block"
         >
         <AssociatedFile name="tag-AFfile4.tex" xmlns="">
         \begin {equation*}x' + y^2 = z_i^2\end {equation*}
         </AssociatedFile>
        <?MarkedContent page="5" ?>x′+y2=z2i
       </Formula>
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0246"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="5" ?>and
       </text>
       <Formula xmlns="http://iso.org/pdf2/ssn"
          id="ID.0247"
          title="equation"
          af="tag-AFfile5.tex"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:Placement="Block"
         >
         <AssociatedFile name="tag-AFfile5.tex" xmlns="">
         \begin {equation}x' + y^2 = z_i^2\end {equation}
         </AssociatedFile>
        <?MarkedContent page="5" ?>x′+y2=z2i
        <Lbl xmlns="http://iso.org/pdf2/ssn"
           id="ID.0248"
          >
         <?MarkedContent page="5" ?>(2.1)
        </Lbl>
       </Formula>
       <text xmlns="https://www.latex-project.org/ns/dflt"
          id="ID.0249"
          xmlns:Layout="http://iso.org/pdf/ssn/Layout"
          Layout:TextAlign="Justify"
          rolemaps-to="P"
         >
        <?MarkedContent page="5" ?>also supported are all of the amsmath environments.
       </text>
      </text-unit>
     </Sect>
    </Sect>
   </Sect>

\usepackage{kantlipsum}

\newtheoremstyle{myplain}
  {}          % ABOVESPACE
  {0pt}       % BELOWSPACE
  {\itshape}  % BODYFONT
  {0pt}       % INDENT (empty value is the same as 0pt)
  {\bfseries} % HEADFONT
  {.}         % HEADPUNCT
  {5pt plus 1pt minus 1pt} % HEADSPACE
  {}          % CUSTOM-HEAD-SPEC
\theoremstyle{myplain}
\newtheorem{mytheorem}{My Theorem}

\START

\ShowInstanceValues{thmstyle}{myplain}
\ShowInstanceValues{block}{thm-myplain-1}

\OMIT
\begin{document}
\TIMO

\kant[1][1-2]
\begin{mytheorem}[a note]
\kant[1][1-2]
\end{mytheorem}
\kant[1][1-2]


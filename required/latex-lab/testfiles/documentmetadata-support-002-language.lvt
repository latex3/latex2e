\DocumentMetadata{language=[de]{de-AT},otherlanguages={fr,en-US}}
\input{regression-test}

\START
\TEST{language}
 {
   \ASSERT{\GetDocumentProperty{document/language}}{de-AT}
 }  
\TEST{language}
 {
   \ASSERT{\GetDocumentProperty{document/otherlanguages}}{fr,en-US}
 }  
\TEST{lang}
 {
   \ASSERT{\GetDocumentProperty{document/lang}}{de}
 }  
\OMIT
\documentclass{article}
\TIMO
\TEST{language}
 {
   \ASSERT{\GetDocumentProperty{document/language}}{de-AT}
 }  
\TEST{language}
 {
   \ASSERT{\GetDocumentProperty{document/otherlanguages}}{fr,en-US}
 }  
\TEST{lang}
 {
   \ASSERT{\GetDocumentProperty{document/lang}}{de}
 } 
\END
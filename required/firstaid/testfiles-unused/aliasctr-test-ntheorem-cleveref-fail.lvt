\input{regression-test}
\documentclass{report}
\usepackage{hyperref}
\def\lemmaautorefname{Lemma}%
\usepackage{ntheorem}
% firstaid would look like this
\makeatletter
   \gdef\@othm#1[#2]#3{%
    \@ifundefined{c@#2}{\@nocounterr{#2}}%
   {\ifthm@tempif
     \newaliascounter{#1}{#2}% new
     %\global\@namedef{the#1}{\@nameuse{the#2}}% removed
     \expandafter\protected@xdef\csname num@addtheoremline#1\endcsname{%
              \noexpand\@num@addtheoremline{#1}{#3}}%
     \expandafter\protected@xdef\csname nonum@addtheoremline#1\endcsname{%
              \noexpand\@nonum@addtheoremline{#1}{#3}}%
    \theoremkeyword{#3}%
    \expandafter\protected@xdef\csname #1Keyword\endcsname
             {\the\theoremkeyword}%
     \expandafter\gdef\csname mkheader@#1\endcsname
       {\csname setparms@#1\endcsname
                \@thm{#1}{#1}{#3}}% changed {#1}{#2} into {#1}{#2}
     \global\@namedef{end#1}{\@endtheorem}\fi}}
\makeatother     
     
\usepackage{cleveref}

\newtheorem{theorem}{Theorem}
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{definition}[theorem]{Definition}
\def\thelemma{\Alph{lemma}}

\begin{document}
\START\showoutput
\makeatletter

\begin{theorem}\label{theorem1}
    theorem counter: \@currentcounter
\end{theorem}

\begin{theorem}\label{theorem2}
    theorem counter: \@currentcounter
\end{theorem}

\begin{lemma}\label{lemma1}
   lemma counter: \@currentcounter
\end{lemma}

\begin{theorem}\label{theorem3}
    theorem counter: \@currentcounter
\end{theorem}

\begin{definition}\label{def}
   definition counter: \@currentcounter
\end{definition}
\newpage
\autoref{lemma1}, \autoref{theorem1}
\cref{lemma1},\cref{theorem2},\cref{theorem3},\cref{def}
\end{document}

